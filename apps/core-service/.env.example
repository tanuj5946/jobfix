# ============================================================
# Core Service — Environment Variables
# Copy to .env and fill in your values before running locally.
# NEVER commit .env to version control.
# ============================================================

# PostgreSQL connection string
# If using Supabase: use the "Transaction pooler" URL (port 6543) here.
# Prisma needs pgbouncer=true with Supabase's pooler to avoid prepared statement collisions.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5&pool_timeout=30"

# Direct connection for Prisma migrations (bypasses pgBouncer pooler).
# If using local Postgres: same as DATABASE_URL above.
# If using Supabase: use the "Direct connection" URL (port 5432, NOT 6543).
#   Find it in: Supabase Dashboard → Settings → Database → Connection string → Direct connection
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres"

# JWT signing secret — use a long, random string in production
JWT_SECRET="change_this_to_a_long_random_secret"

# Access-token expiry (for example: 24h, 15m)
ACCESS_TOKEN_EXPIRES="24h"

# Reserved for a future refresh-token flow; no refresh token is currently issued.
REFRESH_TOKEN_EXPIRES="7d"

# Port the core-service listens on
PORT=3001

# URL where ai-service is running (managed separately — see apps/ai-service)
# Set this to wherever you run the ai-service locally or in staging.
AI_SERVICE_URL="http://localhost:8000"

# Shared secret used only for Core <-> AI internal HTTP requests.
# Generate a long random value and configure the exact same value in ai-service.
INTERNAL_API_KEY="replace-with-a-long-random-internal-api-key"


# Development admin account created by `npm run seed:admin`.
# Use distinct, secret values in shared or production environments.
ADMIN_NAME="JobFix Admin"
ADMIN_EMAIL="admin@jobfix.local"
ADMIN_PASSWORD="Admin@12345"


# CORS — comma-separated list of allowed origins
# AWS SES (required for email verification). SES_FROM_EMAIL must be a verified
# sender identity in the selected SES region.
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
SES_FROM_EMAIL=""

# Public frontend URL. Verification emails link to /verify-email on this app.
FRONTEND_URL="https://job-fix.in"

CORS_ORIGINS="http://localhost:5173"

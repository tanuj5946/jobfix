generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               Int               @id @default(autoincrement())
  role             String
  name             String            @db.VarChar(150)
  email            String            @unique @db.VarChar(255)
  passwordHash     String            @map("password_hash")
  emailVerified    Boolean           @default(false) @map("email_verified")
  emailVerificationToken String?     @unique @map("email_verification_token")
  emailVerificationExpiresAt DateTime? @map("email_verification_expires_at")
  passwordResetToken String?         @unique @map("password_reset_token")
  passwordResetExpiresAt DateTime?   @map("password_reset_expires_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  candidateProfile CandidateProfile?
  recruiterProfile RecruiterProfile?

  @@map("users")
}

model CandidateProfile {
  id                      Int                      @id @default(autoincrement())
  userId                  Int                      @unique @map("user_id")
  resumeUrl               String?                  @map("resume_url")
  resumeText              String?                  @map("resume_text")
  parsedResumeJson        Json?                    @map("parsed_resume_json")
  targetRole              String?                  @map("target_role") @db.VarChar(150)
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  assessmentAttempts      AssessmentAttempt[]
  assessments             Assessment[]
  applications            Application[]
  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidateSkills         CandidateSkill[]
  jobMatches              JobMatch[]
  learningRecommendations LearningRecommendation[]

  @@map("candidate_profiles")
}

model RecruiterProfile {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique @map("user_id")
  companyName    String?  @map("company_name") @db.VarChar(200)
  companyWebsite String?  @map("company_website")
  industry       String?  @db.VarChar(100)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  jobs           Job[]
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("recruiter_profiles")
}

model Skill {
  id                      Int                      @id @default(autoincrement())
  name                    String                   @unique @db.VarChar(100)
  category                String?                  @db.VarChar(100)
  description             String?
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  assessmentQuestions     AssessmentQuestion[]
  assessmentSkills        AssessmentSkill[]
  candidateSkills         CandidateSkill[]
  jobRequiredSkills       JobRequiredSkill[]
  learningRecommendations LearningRecommendation[]

  @@map("skills")
}

model CandidateSkill {
  id              Int              @id @default(autoincrement())
  candidateId     Int              @map("candidate_id")
  skillId         Int              @map("skill_id")
  source          String           @default("manually_added")
  parseConfidence Decimal?         @map("parse_confidence") @db.Decimal(5, 2)
  verifiedScore   Decimal?         @map("verified_score") @db.Decimal(5, 2)
  verifiedLevel   String?          @map("verified_level")
  lastAssessedAt  DateTime?        @map("last_assessed_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  candidate       CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  skill           Skill            @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([candidateId, skillId])
  @@index([candidateId], map: "idx_candidate_skills_candidate")
  @@map("candidate_skills")
}

model Assessment {
  id                     Int                  @id @default(autoincrement())
  candidateId            Int                  @map("candidate_id")
  applicationId          Int?                 @unique @map("application_id")
  assessmentName         String?              @map("assessment_name") @db.VarChar(200)
  targetRole             String?              @map("target_role") @db.VarChar(150)
  status                 String               @default("pending")
  startedAt              DateTime?            @map("started_at")
  completedAt            DateTime?            @map("completed_at")
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")
  assessmentMetadataJson Json?                @map("assessment_metadata_json")
  attempts               AssessmentAttempt[]
  questions              AssessmentQuestion[]
  result                 AssessmentResult?
  skills                 AssessmentSkill[]
  candidate              CandidateProfile     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  application            Application?         @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([candidateId], map: "idx_assessments_candidate")
  @@map("assessments")
}

model AssessmentSkill {
  id           Int        @id @default(autoincrement())
  assessmentId Int        @map("assessment_id")
  skillId      Int        @map("skill_id")
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  skill        Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, skillId])
  @@map("assessment_skills")
}

model AssessmentQuestion {
  id             Int                @id @default(autoincrement())
  assessmentId   Int                @map("assessment_id")
  skillId        Int                @map("skill_id")
  questionText   String             @map("question_text")
  questionType   String             @map("question_type")
  difficulty     String?
  optionsJson    Json?              @map("options_json")
  expectedAnswer String?            @map("expected_answer")
  rubric         String?
  testCasesJson  Json?              @map("test_cases_json")
  marks          Decimal            @default(1) @db.Decimal(5, 2)
  generatedByAi  Boolean            @default(true) @map("generated_by_ai")
  createdAt      DateTime           @default(now()) @map("created_at")
  answers        AssessmentAnswer[]
  assessment     Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  skill          Skill              @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([assessmentId], map: "idx_assessment_questions_assessment")
  @@map("assessment_questions")
}

model AssessmentAnswer {
  id              Int                @id @default(autoincrement())
  questionId      Int                @map("question_id")
  candidateAnswer String?            @map("candidate_answer")
  score           Decimal?           @db.Decimal(5, 2)
  evaluationJson  Json?              @map("evaluation_json")
  feedback        String?
  answeredAt      DateTime           @default(now()) @map("answered_at")
  attemptId       BigInt?            @map("attempt_id")
  isCorrect       Boolean?           @map("is_correct")
  marksAwarded    Decimal?           @map("marks_awarded") @db.Decimal(5, 2)
  attempt         AssessmentAttempt? @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question        AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId], map: "idx_assessment_answers_attempt")
  @@map("assessment_answers")
}

model AssessmentAttempt {
  id           BigInt             @id @default(autoincrement())
  assessmentId Int                @map("assessment_id")
  candidateId  Int                @map("candidate_id")
  status       String             @default("submitted")
  startedAt    DateTime           @default(now()) @map("started_at")
  submittedAt  DateTime?          @map("submitted_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  answers      AssessmentAnswer[]
  assessment   Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  candidate    CandidateProfile   @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  results      AssessmentResult[]

  @@index([assessmentId], map: "idx_assessment_attempts_assessment")
  @@index([candidateId], map: "idx_assessment_attempts_candidate")
  @@map("assessment_attempts")
}

model AssessmentResult {
  id                          Int                @id @default(autoincrement())
  assessmentId                Int                @unique @map("assessment_id")
  overallScore                Decimal            @map("overall_score") @db.Decimal(5, 2)
  overallLevel                String?            @map("overall_level")
  skillBreakdownJson          Json?              @map("skill_breakdown_json")
  evaluationSummary           String?            @map("evaluation_summary")
  generatedAt                 DateTime           @default(now()) @map("generated_at")
  attemptId                   BigInt?            @map("attempt_id")
  assessmentGrade             String?            @map("assessment_grade")
  passFail                    String?            @map("pass_fail")
  confidenceScore             Decimal?           @map("confidence_score") @db.Decimal(5, 2)
  recruiterReportJson         Json?              @map("recruiter_report_json")
  learningRecommendationsJson Json?              @map("learning_recommendations_json")
  promptVersionsJson          Json?              @map("prompt_versions_json")
  assessment                  Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  attempt                     AssessmentAttempt? @relation(fields: [attemptId], references: [id])

  @@map("assessment_results")
}

model Job {
  id               Int                @id @default(autoincrement())
  recruiterId      Int                @map("recruiter_id")
  title            String             @db.VarChar(200)
  description      String?
  status           String             @default("draft")
  location         String?            @db.VarChar(150)
  workMode         String?            @map("work_mode")
  experienceLevel  String?            @map("experience_level")
  minVerifiedLevel String?            @map("min_verified_level")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  matches          JobMatch[]
  requiredSkills   JobRequiredSkill[]
  applications     Application[]
  descriptionAnalysis JobDescriptionAnalysis?
  recruiter        RecruiterProfile   @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  @@index([recruiterId], map: "idx_jobs_recruiter")
  @@index([status], map: "idx_jobs_status")
  @@map("jobs")
}

model JobRequiredSkill {
  id         Int    @id @default(autoincrement())
  jobId      Int    @map("job_id")
  skillId    Int    @map("skill_id")
  importance String @default("medium")
  source     String @default("manual")
  job        Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill      Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([jobId, skillId])
  @@map("job_required_skills")
}

model JobDescriptionAnalysis {
  id               Int      @id @default(autoincrement())
  jobId            Int      @unique @map("job_id")
  requiredSkills   Json     @default("[]") @map("required_skills")
  preferredSkills  Json     @default("[]") @map("preferred_skills")
  education        String?
  responsibilities Json     @default("[]")
  experience       String?
  status           String   @default("pending")
  failureReason    String?  @map("failure_reason")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_description_analyses")
}

model Application {
  id               Int      @id @default(autoincrement())
  jobId            Int      @map("job_id")
  candidateId      Int      @map("candidate_id")
  status           String   @default("applied")
  resumeMatchScore Decimal  @db.Decimal(5, 2) @map("resume_match_score")
  matchDetailsJson Json?    @map("match_details_json")
  appliedAt        DateTime @default(now()) @map("applied_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  job        Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate  CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  assessment Assessment?

  @@unique([jobId, candidateId])
  @@index([candidateId], map: "idx_applications_candidate")
  @@index([jobId], map: "idx_applications_job")
  @@map("applications")
}

model JobMatch {
  id            Int              @id @default(autoincrement())
  jobId         Int              @map("job_id")
  candidateId   Int              @map("candidate_id")
  matchScore    Decimal          @map("match_score") @db.Decimal(5, 2)
  aiExplanation String?          @map("ai_explanation")
  matchedAt     DateTime         @default(now()) @map("matched_at")
  candidate     CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job           Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, candidateId])
  @@index([jobId], map: "idx_job_matches_job")
  @@index([candidateId], map: "idx_job_matches_candidate")
  @@map("job_matches")
}

model LearningRecommendation {
  id            Int              @id @default(autoincrement())
  candidateId   Int              @map("candidate_id")
  skillId       Int              @map("skill_id")
  resourceTitle String           @map("resource_title") @db.VarChar(255)
  resourceUrl   String?          @map("resource_url")
  resourceType  String?          @map("resource_type")
  priority      String           @default("medium")
  status        String           @default("pending")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  candidate     CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  skill         Skill            @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([candidateId], map: "idx_learning_recommendations_candidate")
  @@map("learning_recommendations")
}

model QuestionBank {
  id            BigInt                @id @default(autoincrement())
  role          String                @db.VarChar(150)
  skill         String                @db.VarChar(100)
  category      String?               @db.VarChar(100)
  difficulty    String                @db.VarChar(50)
  questionType  String                @map("question_type") @db.VarChar(50)
  questionText  String                @map("question_text")
  options       Json?
  correctAnswer String?               @map("correct_answer")
  rubric        Json?
  tags          String[]              @default([])
  embedding     Unsupported("vector")
  createdAt     DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([role, skill, difficulty, questionType], map: "idx_question_bank_metadata")
  @@map("question_bank")
}

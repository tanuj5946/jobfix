// ============================================================
// Prisma Schema — SmartFresher
// Mapped exactly from smartfresher_example_schema.sql
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")    // pooler (port 6543) with pgbouncer=true — used by the app at runtime
  directUrl = env("DIRECT_URL")      // direct connection (port 5432) — used by prisma migrate
}

// ── 1. USERS & PROFILES ─────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  role         String   // 'candidate' | 'recruiter'
  name         String   @db.VarChar(150)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  candidateProfile CandidateProfile?
  recruiterProfile RecruiterProfile?

  @@map("users")
}

model CandidateProfile {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique @map("user_id")
  resumeUrl        String?  @map("resume_url")
  resumeText       String?  @map("resume_text")
  parsedResumeJson Json?    @map("parsed_resume_json")
  targetRole       String?  @db.VarChar(150) @map("target_role")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidateSkills       CandidateSkill[]
  assessments           Assessment[]
  assessmentAttempts    AssessmentAttempt[]
  jobMatches            JobMatch[]
  learningRecommendations LearningRecommendation[]

  @@map("candidate_profiles")
}

model RecruiterProfile {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique @map("user_id")
  companyName    String   @db.VarChar(200) @map("company_name")
  companyWebsite String?  @map("company_website")
  industry       String?  @db.VarChar(100)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs Job[]

  @@map("recruiter_profiles")
}

// ── 2. SKILLS ────────────────────────────────────────────────

model Skill {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  category    String?  @db.VarChar(100)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  candidateSkills          CandidateSkill[]
  assessmentSkills         AssessmentSkill[]
  assessmentQuestions      AssessmentQuestion[]
  jobRequiredSkills        JobRequiredSkill[]
  learningRecommendations  LearningRecommendation[]

  @@map("skills")
}

model CandidateSkill {
  id             Int       @id @default(autoincrement())
  candidateId    Int       @map("candidate_id")
  skillId        Int       @map("skill_id")
  source         String    @default("manually_added") // 'auto_detected' | 'manually_added'
  parseConfidence Decimal? @db.Decimal(5, 2) @map("parse_confidence")
  verifiedScore  Decimal?  @db.Decimal(5, 2) @map("verified_score")
  verifiedLevel  String?   @map("verified_level") // 'beginner' | 'intermediate' | 'advanced'
  lastAssessedAt DateTime? @map("last_assessed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  candidate CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  skill     Skill            @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([candidateId, skillId])
  @@index([candidateId], name: "idx_candidate_skills_candidate")
  @@map("candidate_skills")
}

// ── 3. ASSESSMENTS ───────────────────────────────────────────

model Assessment {
  id             Int       @id @default(autoincrement())
  candidateId    Int       @map("candidate_id")
  assessmentName String?   @db.VarChar(200) @map("assessment_name")
  targetRole     String?   @db.VarChar(150) @map("target_role")
  status         String    @default("pending") // 'pending'|'in_progress'|'completed'|'abandoned'
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  assessmentMetadataJson Json? @map("assessment_metadata_json")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  candidate  CandidateProfile     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  skills     AssessmentSkill[]
  questions  AssessmentQuestion[]
  attempts   AssessmentAttempt[]
  result     AssessmentResult?

  @@index([candidateId], name: "idx_assessments_candidate")
  @@map("assessments")
}

model AssessmentSkill {
  id           Int @id @default(autoincrement())
  assessmentId Int @map("assessment_id")
  skillId      Int @map("skill_id")

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  skill      Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, skillId])
  @@map("assessment_skills")
}

model AssessmentQuestion {
  id             Int      @id @default(autoincrement())
  assessmentId   Int      @map("assessment_id")
  skillId        Int      @map("skill_id")
  questionText   String   @map("question_text")
  questionType   String   @map("question_type") // 'mcq' | 'coding' | 'conceptual'
  difficulty     String?  // 'easy' | 'medium' | 'hard'
  optionsJson    Json?    @map("options_json")
  expectedAnswer String?  @map("expected_answer")
  rubric         String?
  testCasesJson  Json?    @map("test_cases_json")
  marks          Decimal  @default(1) @db.Decimal(5, 2)
  generatedByAi  Boolean  @default(true) @map("generated_by_ai")
  createdAt      DateTime @default(now()) @map("created_at")

  assessment Assessment        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  skill      Skill             @relation(fields: [skillId], references: [id], onDelete: Cascade)
  answers    AssessmentAnswer[]

  @@index([assessmentId], name: "idx_assessment_questions_assessment")
  @@map("assessment_questions")
}

model AssessmentAnswer {
  id              Int      @id @default(autoincrement())
  questionId      Int      @map("question_id")
  attemptId       BigInt?  @map("attempt_id")
  candidateAnswer String?  @map("candidate_answer")
  score           Decimal? @db.Decimal(5, 2)
  evaluationJson  Json?    @map("evaluation_json")
  feedback        String?
  isCorrect       Boolean? @map("is_correct")
  marksAwarded    Decimal? @db.Decimal(5, 2) @map("marks_awarded")
  answeredAt      DateTime @default(now()) @map("answered_at")

  question AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  attempt  AssessmentAttempt? @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId], name: "idx_assessment_answers_attempt")
  @@map("assessment_answers")
}

model AssessmentAttempt {
  id           BigInt    @id @default(autoincrement())
  assessmentId Int       @map("assessment_id")
  candidateId  Int       @map("candidate_id")
  status       String    @default("submitted")
  startedAt    DateTime  @default(now()) @map("started_at")
  submittedAt  DateTime? @map("submitted_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  assessment Assessment          @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  candidate  CandidateProfile    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  answers    AssessmentAnswer[]
  results    AssessmentResult[]

  @@index([assessmentId], name: "idx_assessment_attempts_assessment")
  @@index([candidateId], name: "idx_assessment_attempts_candidate")
  @@map("assessment_attempts")
}

model AssessmentResult {
  id                 Int      @id @default(autoincrement())
  assessmentId       Int      @unique @map("assessment_id")
  attemptId          BigInt?  @map("attempt_id")
  overallScore       Decimal  @db.Decimal(5, 2) @map("overall_score")
  overallLevel       String?  @map("overall_level") // 'beginner'|'intermediate'|'advanced'
  skillBreakdownJson Json?    @map("skill_breakdown_json")
  evaluationSummary  String?  @map("evaluation_summary")
  assessmentGrade    String?  @map("assessment_grade")
  passFail           String?  @map("pass_fail")
  confidenceScore    Decimal? @db.Decimal(5, 2) @map("confidence_score")
  recruiterReportJson Json?   @map("recruiter_report_json")
  learningRecommendationsJson Json? @map("learning_recommendations_json")
  promptVersionsJson Json? @map("prompt_versions_json")
  generatedAt        DateTime @default(now()) @map("generated_at")

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  attempt    AssessmentAttempt? @relation(fields: [attemptId], references: [id], onDelete: SetNull)

  @@map("assessment_results")
}

// ── 4. JOBS & MATCHING ───────────────────────────────────────

model Job {
  id               Int      @id @default(autoincrement())
  recruiterId      Int      @map("recruiter_id")
  title            String   @db.VarChar(200)
  description      String?
  status           String   @default("draft") // 'draft'|'published'|'closed'
  location         String?  @db.VarChar(150)
  workMode         String?  @map("work_mode")     // 'remote'|'hybrid'|'onsite'
  experienceLevel  String?  @map("experience_level") // 'fresher'|'1_2_years'|'3_plus_years'
  minVerifiedLevel String?  @map("min_verified_level") // 'beginner'|'intermediate'|'advanced'
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  recruiter      RecruiterProfile   @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  requiredSkills JobRequiredSkill[]
  matches        JobMatch[]

  @@index([recruiterId], name: "idx_jobs_recruiter")
  @@index([status], name: "idx_jobs_status")
  @@map("jobs")
}

model JobRequiredSkill {
  id         Int    @id @default(autoincrement())
  jobId      Int    @map("job_id")
  skillId    Int    @map("skill_id")
  importance String @default("medium") // 'high'|'medium'|'low'

  job   Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([jobId, skillId])
  @@map("job_required_skills")
}

model JobMatch {
  id            Int      @id @default(autoincrement())
  jobId         Int      @map("job_id")
  candidateId   Int      @map("candidate_id")
  matchScore    Decimal  @db.Decimal(5, 2) @map("match_score")
  aiExplanation String?  @map("ai_explanation")
  matchedAt     DateTime @default(now()) @map("matched_at")

  job       Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([jobId, candidateId])
  @@index([jobId], name: "idx_job_matches_job")
  @@index([candidateId], name: "idx_job_matches_candidate")
  @@map("job_matches")
}

// ── 5. CAREER COACH ─────────────────────────────────────────

model LearningRecommendation {
  id            Int      @id @default(autoincrement())
  candidateId   Int      @map("candidate_id")
  skillId       Int      @map("skill_id")
  resourceTitle String   @db.VarChar(255) @map("resource_title")
  resourceUrl   String?  @map("resource_url")
  resourceType  String?  @map("resource_type") // 'course'|'article'|'practice_problems'|'video'
  priority      String   @default("medium") // 'high'|'medium'|'low'
  status        String   @default("pending") // 'pending'|'completed'
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  candidate CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  skill     Skill            @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([candidateId], name: "idx_learning_recommendations_candidate")
  @@map("learning_recommendations")
}

// â”€â”€ 6. QUESTION BANK / RAG â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model QuestionBank {
  id            BigInt   @id @default(autoincrement())
  role          String   @db.VarChar(150)
  skill         String   @db.VarChar(100)
  category      String?  @db.VarChar(100)
  difficulty    String   @db.VarChar(50)
  questionType  String   @map("question_type") @db.VarChar(50)
  questionText  String   @map("question_text")
  options       Json?
  correctAnswer String?  @map("correct_answer")
  rubric        Json?
  tags          String[] @default([])
  embedding     Unsupported("vector")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([role, skill, difficulty, questionType], name: "idx_question_bank_metadata")
  @@map("question_bank")
}
